# ai-news-briefing — example env file
# Copy to `.env` (or `private/.env`) and fill in the keys you have.
# Missing keys make the corresponding agent no-op cleanly; the merger
# accepts thin inputs gracefully.

# ── Anthropic ────────────────────────────────────────────────────────────
# Required for the merger and (after Apr 2026 routing change) the writer +
# translator steps in RSS / Tavily / Perplexity. Either set the API key
# OR use the subscription path below — not both.
ANTHROPIC_API_KEY=sk-ant-...

# Subscription path: route Anthropic calls through `claude -p` (Claude Max
# OAuth credentials). Zero per-call cost. Requires `claude` CLI installed.
# When set, leave ANTHROPIC_API_KEY UNSET to hard-block accidental API use.
# MERGER_VIA_CLAUDE_CODE=1
# MERGER_CC_MODEL=claude-opus-4-7
# MERGER_CC_EFFORT=low

# Per-agent model overrides (defaults shown — tune for cost/quality tradeoffs).
MERGER_WRITER_MODEL=claude-sonnet-4-6
MERGER_TRANSLATOR_MODEL=claude-sonnet-4-6
RSS_WRITER_MODEL=claude-haiku-4-5-20251001
RSS_TRANSLATOR_MODEL=claude-haiku-4-5-20251001
TAVILY_WRITER_MODEL=claude-haiku-4-5-20251001
TAVILY_TRANSLATOR_MODEL=claude-haiku-4-5-20251001

# ── Google (ADK + YouTube) ───────────────────────────────────────────────
GOOGLE_API_KEY=AIza...
GOOGLE_GENAI_MODEL=gemini-2.5-flash
YOUTUBE_API_KEY=AIza...

# ── Perplexity (Sonar search) ────────────────────────────────────────────
PERPLEXITY_API_KEY=pplx-...
PERPLEXITY_SEARCH_MODEL=anthropic/claude-haiku-4-5

# ── Tavily (3-key cascade → DDG fallback) ────────────────────────────────
TAVILY_API_KEY=tvly-...
TAVILY_API_KEY2=tvly-...
TAVILY_API_KEY3=tvly-...

# ── Article enrichment ───────────────────────────────────────────────────
JINA_API_KEY=jina_...
JINA_API_KEY2=jina_...
FIRECRAWL_API_KEY=fc-...
# SKIP_ARTICLE_READING=true   # uncomment to disable enrichment entirely

# ── Supplemental collectors ──────────────────────────────────────────────
EXA_API_KEY=...
EXA_API_KEY2=...
NEWSAPI_KEY=...
NEWSAPI_KEY2=...
GITHUB_TOKEN=ghp_...        # optional — raises rate limit

# ── Twitter scrape (cookies from a logged-in x.com session) ──────────────
# DevTools → Application → Cookies → x.com → copy auth_token + ct0
TWITTER_AUTH_TOKEN=...
TWITTER_CT0=...

# ── xAI (disabled by default — Twitter scrape replaces it) ───────────────
# XAI_API_KEY=xai-...

# ── Hebrew translation for Reddit + X posts (publish_data.py) ────────────
DEEPL_API_KEY=...

# ── Email (send_email.py) ────────────────────────────────────────────────
GMAIL_APP_PASSWORD=...      # Google App Password (16 chars)

# ── Tunables ─────────────────────────────────────────────────────────────
LOOKBACK_DAYS=3
AGENT_TIMEOUT=480           # per-process timeout in run_all.py
